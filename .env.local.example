# Copy to .env.local and fill in values.
# Never commit .env.local — it is gitignored.
# Every PR that adds a new env var must update this file.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # server-side only — never expose to client

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Restrict this key to your domain(s) in Google Cloud Console to prevent abuse.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── AI chatbot ──────────────────────────────────────────────────────────────
# OpenAI → API Keys — server-side only
OPENAI_API_KEY="sk-..."
